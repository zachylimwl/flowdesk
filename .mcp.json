{
  "mcpServers": {
    "mui": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@mui/mcp@latest"
      ],
      "env": {}
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "prisma": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "prisma",
        "mcp"
      ],
      "env": {}
    }
  }
}