{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch"
    ],
    "ask": [
      "Write",
      "Edit",
      "Bash(npm run *)",
      "Bash(npx prisma *)",
      "Bash(git *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.claude/settings.local.json)",
      "Read(node_modules/**)",
      "Read(**/node_modules/**)",
      "Read(dist/**)",
      "Read(build/**)",
      "Read(.next/**)",
      "Read(prisma/generated/**)",
      "Read(coverage/**)",
      "Read(package-lock.json)",
      "Read(yarn.lock)",
      "Read(pnpm-lock.yaml)",
      "Read(apps/web/src/routeTree.gen.ts)"
    ]
  }
}