{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch"
    ],
    "ask": [
      "Write",
      "Edit",
      "Bash(npm run *)",
      "Bash(npx prisma *)",
      "Bash(git *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.claude/settings.local.json)"
    ]
  }
}